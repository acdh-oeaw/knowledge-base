{
	"name": "@acdh-knowledge-base/knowledge-base",
	"private": true,
	"license": "MIT",
	"type": "module",
	"scripts": {
		"analyze": "next experimental-analyze",
		"build": "next build --experimental-next-config-strip-types",
		"dev": "PORT=3001 next dev --experimental-next-config-strip-types",
		"dev:watch": "PORT=3001 next dev --experimental-next-config-strip-types",
		"format:check": "oxfmt --check",
		"format:fix": "oxfmt --write",
		"i18n:convert-messages": "tsx ./scripts/i18n/convert-messages.ts",
		"i18n:extract-messages": "tsx ./scripts/i18n/extract-messages.ts",
		"lint:check": "run-p --continue-on-error \"lint:*:check\"",
		"lint:code:check": "oxlint --report-unused-disable-directives --type-aware --type-check",
		"lint:code:fix": "oxlint --fix --report-unused-disable-directives --type-aware --type-check",
		"lint:fix": "run-p --continue-on-error \"lint:*:fix\"",
		"lint:styles:check": "stylelint \"./styles/**/*.css\" --cache --ignore-path ./../../.gitignore",
		"lint:styles:fix": "stylelint \"./styles/**/*.css\" --cache --fix --ignore-path ./../../.gitignore",
		"prepare": "run-s types:prepare",
		"start": "PORT=3001 next start --experimental-next-config-strip-types",
		"test": "dotenvx run -q -f ./.env.local --ignore MISSING_ENV_FILE -- vitest run",
		"test:e2e": "PORT=3001 playwright test --config ./e2e/playwright.config.ts",
		"test:e2e:codegen": "playwright codegen",
		"test:e2e:install": "playwright install --with-deps",
		"test:e2e:ui": "pnpm run test:e2e --ui",
		"test:e2e:update-snapshots": "pnpm run test:e2e --update-snapshots",
		"test:watch": "dotenvx run -q -f ./.env.local --ignore MISSING_ENV_FILE -- vitest watch",
		"types:check": "tsc --noEmit",
		"types:prepare": "ENV_VALIDATION=\"disabled\" next typegen"
	},
	"dependencies": {
		"@acdh-oeaw/color-schemes": "catalog:",
		"@acdh-oeaw/lib": "catalog:",
		"@acdh-oeaw/style-variants": "catalog:",
		"@acdh-knowledge-base/auth": "workspace:^",
		"@acdh-knowledge-base/client-sshoc": "workspace:^",
		"@acdh-knowledge-base/client-zotero": "workspace:^",
		"@acdh-knowledge-base/database": "workspace:^",
		"@acdh-knowledge-base/email": "workspace:^",
		"@acdh-knowledge-base/env": "workspace:^",
		"@acdh-knowledge-base/images": "workspace:^",
		"@acdh-knowledge-base/next-lib": "workspace:^",
		"@acdh-knowledge-base/rate-limiter": "workspace:^",
		"@acdh-knowledge-base/request": "workspace:^",
		"@acdh-knowledge-base/search": "workspace:^",
		"@acdh-knowledge-base/search-resources": "workspace:^",
		"@acdh-knowledge-base/search-website": "workspace:^",
		"@acdh-knowledge-base/sshoc-services": "workspace:^",
		"@acdh-knowledge-base/storage": "workspace:^",
		"@acdh-knowledge-base/ui": "workspace:^",
		"@heroicons/react": "catalog:",
		"@internationalized/date": "catalog:",
		"@react-aria/utils": "catalog:",
		"@sindresorhus/slugify": "catalog:",
		"@tiptap/core": "catalog:",
		"@tiptap/starter-kit": "catalog:",
		"@tiptap/static-renderer": "catalog:",
		"@valibot/i18n": "catalog:",
		"better-result": "catalog:",
		"client-only": "catalog:",
		"clsx": "catalog:",
		"is-network-error": "catalog:",
		"lucide-react": "catalog:",
		"motion": "catalog:",
		"next": "catalog:",
		"next-intl": "catalog:",
		"nodemailer": "catalog:",
		"pdfkit": "catalog:",
		"react": "catalog:",
		"react-aria": "catalog:",
		"react-aria-components": "catalog:",
		"react-dom": "catalog:",
		"react-schemaorg": "catalog:",
		"server-nodejs-only": "catalog:",
		"server-only": "catalog:",
		"sharp": "catalog:",
		"sonner": "catalog:",
		"tailwind-merge": "catalog:",
		"tailwind-variants": "catalog:",
		"uqr": "catalog:",
		"use-debounce": "catalog:",
		"uuid": "catalog:",
		"valibot": "catalog:"
	},
	"devDependencies": {
		"@acdh-knowledge-base/configs": "workspace:^",
		"@dotenvx/dotenvx": "catalog:",
		"@faker-js/faker": "catalog:",
		"@playwright/test": "catalog:",
		"@react-aria/optimize-locales-plugin": "catalog:",
		"@tailwindcss/postcss": "catalog:",
		"@types/node": "catalog:",
		"@types/nodemailer": "catalog:",
		"@types/pdfkit": "catalog:",
		"@types/react": "catalog:",
		"@types/react-dom": "catalog:",
		"axe-core": "catalog:",
		"axe-playwright": "catalog:",
		"babel-plugin-react-compiler": "catalog:",
		"concurrently": "catalog:",
		"is-in-ci": "catalog:",
		"next-devtools-mcp": "catalog:",
		"npm-run-all2": "catalog:",
		"null-loader": "catalog:",
		"po-parser": "catalog:",
		"schema-dts": "catalog:",
		"stylelint": "catalog:",
		"tailwindcss": "catalog:",
		"tailwindcss-react-aria-components": "catalog:",
		"tsx": "catalog:",
		"tw-animate-css": "catalog:",
		"typescript": "catalog:",
		"vite-tsconfig-paths": "catalog:",
		"vitest": "catalog:"
	},
	"stylelint": {
		"extends": "@acdh-knowledge-base/configs/stylelint/base"
	},
	"engines": {
		"node": "24.x"
	},
	"postcss": {
		"plugins": {
			"@tailwindcss/postcss": {}
		}
	}
}
