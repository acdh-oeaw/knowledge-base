{
	"name": "@acdh-knowledge-base/api",
	"private": true,
	"license": "MIT",
	"type": "module",
	"scripts": {
		"build": "tsdown ./src/index.ts",
		"dev": "dotenvx run -q -f ./.env.local --ignore MISSING_ENV_FILE -- tsx watch ./src/index.ts | pino-pretty",
		"dev:watch": "dotenvx run -q -f ./.env.local --ignore MISSING_ENV_FILE -- tsx watch ./src/index.ts | pino-pretty",
		"format:check": "oxfmt --check",
		"format:fix": "oxfmt --write",
		"lint:check": "oxlint --report-unused-disable-directives --type-aware --type-check",
		"lint:fix": "oxlint --fix --report-unused-disable-directives --type-aware --type-check",
		"start": "dotenvx run -q -f ./.env.local --ignore MISSING_ENV_FILE -- node ./dist/index.mjs",
		"test": "dotenvx run -q -f ./.env.local --ignore MISSING_ENV_FILE -- vitest run",
		"test:coverage": "dotenvx run -q -f ./.env.local --ignore MISSING_ENV_FILE -- vitest run --coverage",
		"test:update-snapshots": "dotenvx run -q -f ./.env.local --ignore MISSING_ENV_FILE -- vitest run --update",
		"test:watch": "dotenvx run -q -f ./.env.local --ignore MISSING_ENV_FILE -- vitest watch",
		"types:check": "tsc --noEmit"
	},
	"dependencies": {
		"@acdh-oeaw/lib": "catalog:",
		"@acdh-knowledge-base/database": "workspace:^",
		"@acdh-knowledge-base/env": "workspace:^",
		"@acdh-knowledge-base/images": "workspace:^",
		"@acdh-knowledge-base/mailchimp": "workspace:^",
		"@acdh-knowledge-base/request": "workspace:^",
		"@acdh-knowledge-base/search": "workspace:^",
		"@acdh-knowledge-base/storage": "workspace:^",
		"@hono/node-server": "catalog:",
		"@hono/standard-validator": "catalog:",
		"@hono/swagger-ui": "catalog:",
		"@imgproxy/imgproxy-js-core": "catalog:",
		"@imgproxy/imgproxy-node": "catalog:",
		"@sentry/node": "catalog:",
		"@valibot/to-json-schema": "catalog:",
		"better-result": "catalog:",
		"hono": "catalog:",
		"hono-openapi": "catalog:",
		"hono-pino": "catalog:",
		"hono-rate-limiter": "catalog:",
		"pino": "catalog:",
		"typesense": "catalog:",
		"valibot": "catalog:"
	},
	"devDependencies": {
		"@acdh-oeaw/tsconfig": "catalog:",
		"@acdh-knowledge-base/configs": "workspace:^",
		"@dotenvx/dotenvx": "catalog:",
		"@faker-js/faker": "catalog:",
		"@sindresorhus/slugify": "catalog:",
		"@tiptap/core": "catalog:",
		"@types/node": "catalog:",
		"openapi-types": "catalog:",
		"pino-pretty": "catalog:",
		"tsdown": "catalog:",
		"tsx": "catalog:",
		"typescript": "catalog:",
		"uuid": "catalog:",
		"vite-tsconfig-paths": "catalog:",
		"vitest": "catalog:"
	},
	"engines": {
		"node": "24.x"
	}
}
