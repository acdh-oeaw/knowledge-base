{
	"$schema": "./node_modules/lefthook/schema.json",
	"pre-commit": {
		"commands": {
			"oxlint": {
				"run": "bun oxlint --fix --report-unused-disable-directives --type-aware --type-check {staged_files}",
				"stage_fixed": true
			},
			"stylelint": {
				"glob": "*.css",
				"run": "bun stylelint --fix {staged_files}",
				"stage_fixed": true
			},
			"oxfmt": {
				"run": "bun oxfmt --no-error-on-unmatched-pattern --write {staged_files}",
				"stage_fixed": true
			}
		}
	}
}
